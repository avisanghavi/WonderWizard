# ============================================================
# LabBuddy environment variables
# Copy this file to .env and fill in your secrets.
# ============================================================

# ---- Required: chat copilot ----
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ---- Server ----
PORT=3001
SERVER_PORT=3001
NODE_ENV=development

# ---- Auth ----
# REQUIRED in production. The default in code is a dev placeholder that
# you MUST override. Use a 32+ character random string.
JWT_SECRET=replace-with-a-32-plus-char-random-string

# ============================================================
# Image generation (schematics / DIY step illustrations)
# Provider priority order: FAL_KEY → OPENAI_API_KEY → ANTHROPIC_API_KEY (SVG).
# Set just one and the app picks the best available.
# ============================================================

# Recraft v3 via fal.ai — recommended. Vector/illustration style, ~$0.04/image.
# https://fal.ai/dashboard/keys
FAL_KEY=

# OpenAI gpt-image-1 — alternative fallback, ~$0.04/image at medium quality.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---- Billing (optional) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_YEARLY=
STRIPE_PRICE_CLASSROOM_MONTHLY=
