node_modules/
dist/
.env
.env.local
*.log
.DS_Store
# Exclude runtime app data EXCEPT the curated stock-images bundle, which IS
# committed (it ships with the Docker image). Negations only work when the
# parent directory itself isn't fully excluded, so we use /<path>/* form.
server/data/*
!server/data/stock-images/
/data/
