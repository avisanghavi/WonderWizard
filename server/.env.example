# =============================================================================
# LabBuddy server — environment variables
# Copy to .env (gitignored) and fill in.
# =============================================================================

# --- Runtime ---
NODE_ENV=production
PORT=3001
CLIENT_ORIGIN=https://labbuddy.example.com   # used for CORS + Stripe return URLs

# --- Supabase (REQUIRED) ---
# Project: https://wdoiyhqeldnrjtrlcjvw.supabase.co
SUPABASE_URL=https://wdoiyhqeldnrjtrlcjvw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # service_role JWT (server-only, NEVER expose)

# --- Anthropic (REQUIRED) ---
ANTHROPIC_API_KEY=

# --- Image generation (optional — pipeline falls back to Claude-SVG if both empty) ---
FAL_KEY=
OPENAI_API_KEY=

# --- Stripe billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_YEARLY=
STRIPE_PRICE_CLASSROOM_MONTHLY=
